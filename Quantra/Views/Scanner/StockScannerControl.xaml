<UserControl x:Class="Quantra.Views.Scanner.StockScannerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quantra.Views.Scanner"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100"
             Background="#1E1E30"
             MinWidth="500" MinHeight="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/EnhancedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:ScannerSignColorConverter x:Key="SignColor"/>
            <local:NullableDoubleFormatConverter x:Key="NullableDouble"/>
            <local:NullableRvolConverter x:Key="NullableRvol"/>
            <local:FloatSharesFormatConverter x:Key="FloatShares"/>
            <local:MarketCapFormatConverter x:Key="MarketCapFmt"/>
            <local:VolumeFormatConverter x:Key="VolumeFmt"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Radar" Width="24" Height="24" Foreground="Cyan"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Real-Time Stock Scanner" FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto" IsChecked="True"
                          Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"
                          Checked="AutoRefreshCheckBox_Changed" Unchecked="AutoRefreshCheckBox_Changed"/>
                <TextBlock Text="Interval (s):" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="IntervalTextBox" Width="50" Text="30"
                         Background="#2D2D42" Foreground="White" BorderBrush="#3E3E56"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"
                         LostFocus="IntervalTextBox_LostFocus"/>
                <Button x:Name="EnrichButton" Content="Enrich" Width="80" Height="30"
                        Background="#3E3E56" Foreground="White" BorderBrush="Cyan"
                        Click="EnrichButton_Click" Margin="0,0,6,0"
                        ToolTip="Fetch fundamentals (Float, Short %) + daily stats (RVOL, ATR %)"/>
                <Button x:Name="RefreshButton" Content="Refresh" Width="80" Height="30"
                        Background="#3E3E56" Foreground="White" BorderBrush="Cyan"
                        Click="RefreshButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Symbols + preset -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Symbols:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="SymbolsTextBox" Width="600" Height="28"
                         Background="#2D2D42" Foreground="White" BorderBrush="#3E3E56"
                         VerticalContentAlignment="Center"
                         ToolTip="Comma-separated ticker list (up to 100 per bulk call; more are batched)."
                         Text="AAPL,MSFT,NVDA,AMD,TSLA,AMZN,GOOGL,META,NFLX,SPY,QQQ,IWM"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Preset:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="PresetComboBox" Width="220" Height="28"
                          Background="#2D2D42" Foreground="White" BorderBrush="#3E3E56"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="PresetComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="2" x:Name="LoadingIndicator" IsIndeterminate="True"
                     Height="4" Margin="0,0,0,6" Visibility="Collapsed" Foreground="Cyan"/>

        <!-- Results grid -->
        <Border Grid.Row="3" Background="#2D2D42" BorderBrush="#3E3E56" BorderThickness="1">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      Background="#2D2D42" Foreground="White"
                      BorderThickness="0"
                      RowBackground="#2D2D42"
                      AlternatingRowBackground="#262638"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3E3E56"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      ColumnHeaderStyle="{StaticResource EnhancedDataGridColumnHeaderStyle}"
                      MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" MinWidth="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1E90FF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=\{0:F2\}}" MinWidth="70"/>

                    <DataGridTemplateColumn Header="Chg %" MinWidth="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ChangePercent, StringFormat='\{0:+0.00;-0.00\}%'}"
                                           Foreground="{Binding ChangePercent, Converter={StaticResource SignColor}}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Gap %" MinWidth="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GapPercent, StringFormat='\{0:+0.00;-0.00\}%'}"
                                           Foreground="{Binding GapPercent, Converter={StaticResource SignColor}}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Volume"
                                        Binding="{Binding Volume, Converter={StaticResource VolumeFmt}}"
                                        MinWidth="90"/>

                    <DataGridTextColumn Header="RVOL"
                                        Binding="{Binding Rvol, Converter={StaticResource NullableRvol}}"
                                        MinWidth="70"/>

                    <DataGridTextColumn Header="ATR %"
                                        Binding="{Binding AtrPercent, Converter={StaticResource NullableDouble}, ConverterParameter=pct}"
                                        MinWidth="70"/>

                    <DataGridTemplateColumn Header="VWAP Dev %" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding VwapDeviationPercent, StringFormat='\{0:+0.00;-0.00\}%'}"
                                           Foreground="{Binding VwapDeviationPercent, Converter={StaticResource SignColor}}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Pre-Mkt Chg %"
                                        Binding="{Binding PreMarketChangePercent, Converter={StaticResource NullableDouble}, ConverterParameter=signpct}"
                                        MinWidth="100"/>

                    <DataGridTextColumn Header="Pre-Mkt Vol"
                                        Binding="{Binding PreMarketVolume, Converter={StaticResource NullableDouble}, ConverterParameter=vol}"
                                        MinWidth="90"/>

                    <DataGridTextColumn Header="Float"
                                        Binding="{Binding FloatShares, Converter={StaticResource FloatShares}}"
                                        MinWidth="80"/>

                    <DataGridTextColumn Header="Short Float %"
                                        Binding="{Binding ShortFloatPercent, Converter={StaticResource NullableDouble}, ConverterParameter=pct}"
                                        MinWidth="90"/>

                    <DataGridTextColumn Header="Mkt Cap"
                                        Binding="{Binding MarketCap, Converter={StaticResource MarketCapFmt}}"
                                        MinWidth="90"/>

                    <DataGridTemplateColumn Header="Warnings" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WarningsLabel}"
                                           Foreground="#FFCC55" FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding WarningsLabel}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="4" x:Name="StatusText" Text="Ready."
                   Foreground="#AAAAAA" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
